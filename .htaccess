# Custom error pages
ErrorDocument 404 /404.html

# Serve HTML content for the root
DirectoryIndex index.html index.htm

# Enable rewrite engine
RewriteEngine On
RewriteBase /

# Redirect www to non-www (canonical domain)
RewriteCond %{HTTP_HOST} ^www\.johnb\.io [NC]
RewriteRule ^ https://johnb.io%{REQUEST_URI} [R=301,L]

# Strip .html extension — redirect /page.html to /page
RewriteCond %{THE_REQUEST} /([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Force the home page to use index.html
RewriteRule ^$ index.html [L]

# Serve news directory index directly (bypass Passenger)
RewriteRule ^news/?$ news/index.html [L]

# Serve course directory index directly (bypass Passenger)
RewriteRule ^course/?$ course/index.html [L]

# Route /verify/{certId} to verify.html (public certificate verification)
RewriteRule ^verify/[A-Z0-9-]+$ /verify.html [L]

# Handle HTML file extensions
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ $1.html [L]

# Enable range requests for audio files (allows browser to stream/seek)
<IfModule mod_headers.c>
    <FilesMatch "\.(mp3|m4a|mp4|ogg|wav)$">
        Header set Accept-Ranges bytes
    </FilesMatch>
</IfModule>

# Handle font files caching
<IfModule mod_headers.c>
    <FilesMatch "\.(ttf|otf|eot|woff|woff2)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # Specific rule for CORBEL.TTF
    <Files "CORBEL.TTF">
        Header set Cache-Control "max-age=31536000, public"
    </Files>
</IfModule>

# Enable expires headers
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS, JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # Others
    ExpiresDefault "access plus 1 month"
</IfModule>

# Add version to static assets
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.+)\.(\d+)\.(bmp|css|cur|gif|ico|jpe?g|js|png|svgz?|webp|webmanifest)$ $1.$3 [L]
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript text/javascript application/json
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://cdn.amcharts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.ukjbowman.workers.dev https://*.googleapis.com https://*.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; frame-src 'none'; object-src 'none';"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
</IfModule>

# Prevent directory listing
Options -Indexes

# Prevent access to .htaccess file
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# Block server error log from public access
<Files "error_log">
    Order allow,deny
    Deny from all
</Files>


# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION BEGIN
<IfModule Litespeed>
</IfModule>
# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION END

AddType text/css .css
AddType audio/mpeg .mp3
AddType audio/mp4 .m4a
AddType audio/x-m4a .m4a
